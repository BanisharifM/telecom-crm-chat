telecomco.chat {
    # FastAPI backend
    # Browser requests /api/query/health -> Caddy strips /query -> backend gets /api/health
    route /api/query/* {
        uri path_regexp /api/query(.*) /api$1
        reverse_proxy backend:8000
    }

    # Next.js frontend
    route {
        reverse_proxy frontend:3000
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    encode gzip
}
